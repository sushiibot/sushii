# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in the values

# Discord Bot Configuration (requires a separate test bot application)
E2E_DISCORD_TOKEN=your_test_bot_token_here
E2E_APPLICATION_ID=your_test_application_id_here

# Test Guild Configuration
E2E_OWNER_USER_ID=your_discord_user_id_here
E2E_TEST_CHANNEL_ID=your_test_channel_id_here

# E2E Webhook Configuration (for deployment testing)
# Create a webhook in your test channel and use the URL here
# Format: https://discord.com/api/webhooks/{webhook_id}/{webhook_token}
E2E_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id_here/your_webhook_token_here

# Note: You'll need to:
# 1. Create a separate Discord bot application for testing
# 2. Create a test Discord server/guild
# 3. Add the test bot to your test server
# 4. Create a webhook in your test channel for deployment testing
# 5. Replace the placeholder values above with actual IDs